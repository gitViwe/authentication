@page "/"
@page "/index.html"
@inject IJSRuntime JS

<PageTitle>Home</PageTitle>

<MudGrid Justify="Justify.Center">
    <MudItem xs="12" sm="12" md="12" Class="d-flex justify-space-between flex-grow-1 gap-4 mt-2">

        <MudButton Color="Color.Primary"
                   Size="Size.Large"
                   Disabled=@(_authenticationType == AuthenticationType.Register)
                   OnClick="@(() => _authenticationType = AuthenticationType.Register)">
            Create a passkey
        </MudButton>

        <MudButton Color="Color.Primary"
                   Size="Size.Large"
                   Disabled=@(_authenticationType == AuthenticationType.Login)
                   OnClick="@(() => _authenticationType = AuthenticationType.Login)">
            Authenticate with passkey
        </MudButton>

    </MudItem>
</MudGrid>

@if (_authenticationType == AuthenticationType.Register)
{
    <EditForm Model="@Model" OnValidSubmit="RegisterAsync">

        <DataAnnotationsValidator />

        <MudTextField Label="Email Address"
                      @bind-Value="Model.RegisterUserEmail"
                      For="@(() => Model.RegisterUserEmail)"
                      Variant="Variant.Outlined"
                      Class="my-6" />

        <MudStack Spacing="2">
            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       Disabled="_processing"
                       FullWidth="true">
                @if (_processing)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Processing</MudText>
                }
                else
                {
                    <MudText>Register</MudText>
                }
            </MudButton>
        </MudStack>

    </EditForm>
}
else if (_authenticationType == AuthenticationType.Login)
{
    <MudStack Spacing="2" Class="my-6">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   OnClick="AuthenticateAsync"
                   Disabled="_processing"
                   FullWidth="true">
            @if (_processing)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Processing</MudText>
            }
            else
            {
                <MudText>Authenticate</MudText>
            }
        </MudButton>
    </MudStack>
}
